{
  "manifest_version": 3,
  "name": "TextTutor",
  "version": "1.0.0",
  "description": "Highlight any text and get an embedded video explanation at the right timestamp.",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:5001/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TextTutor"
  }
}
