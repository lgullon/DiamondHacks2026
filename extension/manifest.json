{
  "manifest_version": 3,
  "name": "SmartCookie",
  "version": "1.0.0",
  "description": "Highlight any text and get an embedded video explanation at the right timestamp.",
  "permissions": ["activeTab"],
  "host_permissions": ["http://localhost:5001/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "mainChip.png",
    "48": "mainChip.png",
    "128": "mainChip.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SmartCookie",
    "default_icon": {
      "16": "mainChip.png",
      "48": "mainChip.png",
      "128": "mainChip.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["mainChip.png", "chipChomp1.png", "chipChomp2.png", "chipChomp3.png", "chipChomp4.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
