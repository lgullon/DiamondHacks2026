{
  "name": "formbuddy",
  "displayName": "FormBuddy",
  "version": "0.0.1",
  "description": "Multilingual form assistant",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "^0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.0",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "tabs",
      "activeTab",
      "scripting"
    ]
  }
}
